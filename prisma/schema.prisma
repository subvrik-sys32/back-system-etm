generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id          String           @id @default(uuid())
  name        String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  active      Boolean          @default(true)
  code        String           @unique
  color       String
  icon        String
  permissions RolePermission[]
  users       User[]
}

model Permission {
  id          String           @id @default(uuid())
  code        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Client {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  color     String
  icon      String
  projects  Project[]
}

model User {
  id                    String         @id @default(uuid())
  name                  String
  email                 String         @unique
  passwordHash          String
  roleId                String
  active                Boolean        @default(true)
  deletedAt             DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  username              String?        @unique
  color                 String
  icon                  String
  avatarUrl             String?
  phone                 String?
  position              String?
  auditLogs             AuditLog[]
  createdProjects       Project[]      @relation("ProjectCreatedBy")
  managedProjects       Project[]      @relation("ProjectPm")
  updatedProjects       Project[]      @relation("ProjectUpdatedBy")
  createdTasks          Task[]         @relation("TaskCreatedBy")
  updatedTasks          Task[]         @relation("TaskUpdatedBy")
  role                  Role           @relation(fields: [roleId], references: [id])
  workflowSteps         WorkflowStep[]
  comments              Comment[]
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsSent     Notification[] @relation("NotificationActor")
}

model Comment {
  id             String         @id @default(uuid())
  taskId         String
  workflowStepId String?
  userId         String
  message        String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  task           Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  workflowStep   WorkflowStep?  @relation(fields: [workflowStepId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id])
  notifications  Notification[]

  @@index([taskId])
  @@index([workflowStepId])
}

model Notification {
  id             String           @id @default(uuid())
  userId         String
  actorId        String
  type           NotificationType
  taskId         String
  workflowStepId String?
  commentId      String
  messageSnippet String
  read           Boolean          @default(false)
  createdAt      DateTime         @default(now())
  user           User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor          User             @relation("NotificationActor", fields: [actorId], references: [id])
  task           Task             @relation(fields: [taskId], references: [id], onDelete: Cascade)
  workflowStep   WorkflowStep?    @relation(fields: [workflowStepId], references: [id], onDelete: Cascade)
  comment        Comment          @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

enum NotificationType {
  MENTION
  COMMENT
}

model Priority {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  color     String
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  icon      String
  tasks     Task[]
}

model Material {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  color     String
  icon      String
  tasks     Task[]
}

model Thickness {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  color     String
  icon      String
  tasks     Task[]
}

model Color {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  icon      String
  color     String
  tasks     Task[]
}

model Stage {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  color     String
  icon      String
  projects  Project[]
}

model Status {
  id        String    @id @default(uuid())
  code      String    @unique
  name      String
  active    Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  color     String
  icon      String
  projects  Project[]
}

model Project {
  id           String    @id @default(uuid())
  sequence     Int       @unique
  projectCode  String
  name         String
  clientId     String
  deliveryDate DateTime?
  position     Int       @default(0)
  createdById  String
  updatedById  String
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  pmId         String
  stageId      String
  statusId     String
  client       Client    @relation(fields: [clientId], references: [id])
  createdBy    User      @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  pm           User      @relation("ProjectPm", fields: [pmId], references: [id])
  stage        Stage     @relation(fields: [stageId], references: [id])
  status       Status    @relation(fields: [statusId], references: [id])
  updatedBy    User      @relation("ProjectUpdatedBy", fields: [updatedById], references: [id])
  tasks        Task[]

  @@index([clientId])
  @@index([pmId])
}

model Task {
  id            String         @id @default(uuid())
  taskNumber    Int            @unique
  projectId     String
  reference     String
  pieces        Int
  lotNumber     Int
  paintKg       Float
  priorityId    String
  materialId    String
  thicknessId   String
  colorId       String?
  plRt          String?
  deliveryDate  DateTime?
  position      Int            @default(0)
  createdById   String
  updatedById   String
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  assemblyCount Int
  route         ProcessCode[]
  color         Color?         @relation(fields: [colorId], references: [id])
  createdBy     User           @relation("TaskCreatedBy", fields: [createdById], references: [id])
  material      Material       @relation(fields: [materialId], references: [id])
  priority      Priority       @relation(fields: [priorityId], references: [id])
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  thickness     Thickness      @relation(fields: [thicknessId], references: [id])
  updatedBy     User           @relation("TaskUpdatedBy", fields: [updatedById], references: [id])
  workflowSteps WorkflowStep[]
  comments      Comment[]
  notifications Notification[]
}

model WorkflowStep {
  id            String         @id @default(uuid())
  taskId        String
  processCode   ProcessCode
  status        WorkflowStatus
  order         Int
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  paintKgReal   Float?
  piecesOutput  Int?
  plRtReal      Float?
  reviewedAt    DateTime?
  operatorId    String?
  operator      User?          @relation(fields: [operatorId], references: [id])
  task          Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  comments      Comment[]
  notifications Notification[]

  @@unique([taskId, processCode])
  @@index([taskId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  module    String
  entityId  String
  action    String
  oldValue  Json?
  newValue  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

enum ProcessCode {
  CT
  PL
  SD
  PT
  EN
  DS
}

enum WorkflowStatus {
  QUEUE
  PENDING
  PROGRESS
  PAUSED
  COMPLETED
  REVIEWED
}
